{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProAgents Feature Status",
  "description": "Schema for individual feature status tracking",
  "type": "object",
  "required": ["id", "name", "workflow", "phases"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^feature-[a-z0-9-]+$",
      "description": "Unique feature identifier"
    },
    "name": {
      "type": "string",
      "description": "Human-readable feature name"
    },
    "description": {
      "type": "string",
      "description": "Feature description"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "workflow": {
      "type": "object",
      "required": ["mode", "current_phase"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["full", "bug_fix", "quick_change"]
        },
        "entry_point": {
          "type": "string"
        },
        "current_phase": {
          "type": "string"
        },
        "phase_progress": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "phases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "skipped"]
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          },
          "duration_minutes": {
            "type": "integer"
          },
          "progress": {
            "type": "integer"
          },
          "artifacts": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "checkpoints": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "triggered": { "type": "boolean" },
          "approved": { "type": "boolean" },
          "approved_by": { "type": "string" },
          "approved_at": { "type": "string", "format": "date-time" },
          "rejected_reason": { "type": "string" }
        }
      }
    },
    "git": {
      "type": "object",
      "properties": {
        "branch": { "type": "string" },
        "base_branch": { "type": "string" },
        "commits": { "type": "integer" },
        "last_commit": { "type": "string" },
        "pr_number": { "type": ["integer", "null"] },
        "pr_status": { "type": ["string", "null"] }
      }
    },
    "assignees": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "reviewers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "key_decisions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
