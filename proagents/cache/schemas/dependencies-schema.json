{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cache-dependencies-schema.json",
  "title": "Cache Dependencies Schema",
  "description": "Schema for cached project dependencies in the ProAgents analysis cache",
  "type": "object",
  "required": ["version", "generated_at", "package_manager"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "package_manager": {
      "type": "string",
      "enum": ["npm", "yarn", "pnpm", "bun", "pip", "poetry", "cargo", "go"]
    },
    "lockfile": {
      "type": "string"
    },
    "production": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/dependency" }
      }
    },
    "development": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/definitions/dependency" }
      }
    },
    "internal_dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "imports_from": {
            "type": "array",
            "items": { "type": "string" }
          },
          "imported_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "circular_dependencies": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "last_audit": {
          "type": "string",
          "format": "date-time"
        },
        "vulnerabilities": {
          "type": "object",
          "properties": {
            "critical": { "type": "integer", "minimum": 0 },
            "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 },
            "low": { "type": "integer", "minimum": 0 }
          }
        },
        "outdated_packages": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "dependency": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "purpose": { "type": "string" }
      }
    }
  }
}
