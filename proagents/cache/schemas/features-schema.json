{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cache-features-schema.json",
  "title": "Cache Features Schema",
  "description": "Schema for cached discovered features in the ProAgents analysis cache",
  "type": "object",
  "required": ["version", "generated_at", "discovered_features"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "discovered_features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "location"],
        "properties": {
          "name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["implemented", "partial", "planned", "deprecated"]
          },
          "location": { "type": "string" },
          "components": {
            "type": "array",
            "items": { "type": "string" }
          },
          "api_routes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "hooks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "related_files": { "type": "integer", "minimum": 0 },
          "test_coverage": { "type": "number", "minimum": 0, "maximum": 100 },
          "notes": { "type": "string" }
        }
      }
    },
    "ui_components": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "by_category": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "api_endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "methods"],
        "properties": {
          "route": { "type": "string" },
          "methods": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
            }
          },
          "purpose": { "type": "string" }
        }
      }
    },
    "state_stores": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "location": { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },
    "database_models": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "table": { "type": "string" },
          "fields": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
