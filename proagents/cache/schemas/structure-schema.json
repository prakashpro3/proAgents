{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cache-structure-schema.json",
  "title": "Cache Structure Schema",
  "description": "Schema for cached project structure in the ProAgents analysis cache",
  "type": "object",
  "required": ["version", "generated_at", "root", "tree"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "type": "string",
      "description": "Root path of the project"
    },
    "tree": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/tree_node" }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_directories": { "type": "integer", "minimum": 0 },
        "total_files": { "type": "integer", "minimum": 0 },
        "by_extension": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "framework_detection": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "version": { "type": "string" },
        "router": { "type": "string" },
        "additional": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "tree_node": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["directory", "file"]
        },
        "purpose": { "type": "string" },
        "framework": { "type": "string" },
        "pattern": { "type": "string" },
        "file_count": { "type": "integer", "minimum": 0 },
        "children": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/tree_node" }
        }
      }
    }
  }
}
