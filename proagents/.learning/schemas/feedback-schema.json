{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feedback-schema.json",
  "title": "Feedback Schema",
  "description": "Schema for user feedback in the ProAgents learning system",
  "type": "object",
  "required": ["project_id", "version", "updated_at", "feedback_entries"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "feedback_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "type", "rating"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^fb-\\d+$"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "feature_id": {
            "type": "string"
          },
          "phase": {
            "type": "string",
            "enum": ["analysis", "requirements", "design", "planning", "implementation", "testing", "review", "documentation", "deployment"]
          },
          "type": {
            "type": "string",
            "enum": ["positive", "improvement", "negative"]
          },
          "rating": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "comment": {
            "type": "string"
          },
          "context": {
            "type": "object",
            "properties": {
              "suggestion_accepted": { "type": "boolean" },
              "modifications_needed": { "type": "boolean" },
              "modification_type": { "type": "string" },
              "required_restart": { "type": "boolean" }
            }
          },
          "improvement_suggestions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "root_cause": {
            "type": "string"
          },
          "resolution": {
            "type": "string"
          }
        }
      }
    },
    "aggregated_feedback": {
      "type": "object",
      "properties": {
        "total_entries": { "type": "integer", "minimum": 0 },
        "average_rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "positive_count": { "type": "integer", "minimum": 0 },
        "improvement_count": { "type": "integer", "minimum": 0 },
        "negative_count": { "type": "integer", "minimum": 0 },
        "by_phase": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "average_rating": { "type": "number", "minimum": 1, "maximum": 5 },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "common_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "issue": { "type": "string" },
              "frequency": { "type": "integer", "minimum": 0 },
              "status": { "type": "string" }
            }
          }
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "area": { "type": "string" },
              "frequency": { "type": "integer", "minimum": 0 },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "improvement_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^action-\\d+$"
          },
          "created_from": { "type": "string" },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled"]
          },
          "completed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
