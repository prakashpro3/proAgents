{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "patterns-schema.json",
  "title": "Common Patterns Schema",
  "description": "Schema for common code patterns in the ProAgents learning system",
  "type": "object",
  "required": ["version", "updated_at", "patterns"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "patterns": {
      "type": "object",
      "properties": {
        "component_patterns": {
          "type": "array",
          "items": { "$ref": "#/definitions/pattern" }
        },
        "api_patterns": {
          "type": "array",
          "items": { "$ref": "#/definitions/pattern" }
        },
        "error_handling": {
          "type": "array",
          "items": { "$ref": "#/definitions/pattern" }
        },
        "testing_patterns": {
          "type": "array",
          "items": { "$ref": "#/definitions/pattern" }
        }
      }
    },
    "anti_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "detected_count": { "type": "integer", "minimum": 0 },
          "suggestion": { "type": "string" },
          "auto_suggest": { "type": "boolean" }
        }
      }
    },
    "learned_from": {
      "type": "object",
      "properties": {
        "codebase_analysis": { "type": "integer", "minimum": 0 },
        "user_corrections": { "type": "integer", "minimum": 0 },
        "explicit_teaching": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "pattern": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "frequency": { "type": "integer", "minimum": 0, "maximum": 100 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "template": { "type": "string" },
        "applies_to": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
