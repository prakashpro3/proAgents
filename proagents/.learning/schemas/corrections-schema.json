{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "corrections-schema.json",
  "title": "Corrections Schema",
  "description": "Schema for user corrections in the ProAgents learning system",
  "type": "object",
  "required": ["project_id", "version", "updated_at", "corrections"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "corrections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "created_at", "type", "category"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^corr-\\d+$"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string",
            "enum": ["code_pattern", "naming", "error_handling", "imports", "structure", "other"]
          },
          "category": {
            "type": "string"
          },
          "original": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "pattern": { "type": "string" },
              "context": { "type": "string" }
            }
          },
          "corrected": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "pattern": { "type": "string" },
              "context": { "type": "string" }
            }
          },
          "reason": {
            "type": "string"
          },
          "occurrences": {
            "type": "integer",
            "minimum": 1
          },
          "auto_apply": {
            "type": "boolean"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "properties": {
        "total_corrections": { "type": "integer", "minimum": 0 },
        "auto_applied": { "type": "integer", "minimum": 0 },
        "manual_review": { "type": "integer", "minimum": 0 },
        "average_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "time_saved_minutes": { "type": "integer", "minimum": 0 }
      }
    },
    "pending_review": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "correction_id": { "type": "string" },
          "reason": { "type": "string" },
          "suggested_action": { "type": "string" }
        }
      }
    }
  }
}
