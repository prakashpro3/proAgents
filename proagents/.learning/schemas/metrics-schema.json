{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "metrics-schema.json",
  "title": "Metrics Schema",
  "description": "Schema for development metrics in the ProAgents learning system",
  "type": "object",
  "required": ["project_id", "version", "updated_at"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "properties": {
        "features_completed": { "type": "integer", "minimum": 0 },
        "bugs_fixed": { "type": "integer", "minimum": 0 },
        "total_development_hours": { "type": "number", "minimum": 0 },
        "average_feature_duration_hours": { "type": "number", "minimum": 0 },
        "average_bug_fix_duration_hours": { "type": "number", "minimum": 0 }
      }
    },
    "phase_durations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "average_minutes": { "type": "number", "minimum": 0 },
          "min_minutes": { "type": "number", "minimum": 0 },
          "max_minutes": { "type": "number", "minimum": 0 },
          "samples": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "checkpoint_metrics": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "average_wait_minutes": { "type": "number", "minimum": 0 },
          "skip_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "approval_rate": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "efficiency_trends": {
      "type": "object",
      "properties": {
        "weekly": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "week": { "type": "string", "pattern": "^\\d{4}-W\\d{2}$" },
              "features": { "type": "integer", "minimum": 0 },
              "avg_duration_hours": { "type": "number", "minimum": 0 }
            }
          }
        },
        "improvement_rate": { "type": "number" },
        "trend": {
          "type": "string",
          "enum": ["improving", "stable", "declining"]
        }
      }
    },
    "quality_metrics": {
      "type": "object",
      "properties": {
        "test_coverage_average": { "type": "number", "minimum": 0, "maximum": 100 },
        "bugs_per_feature": { "type": "number", "minimum": 0 },
        "rework_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "code_review_iterations_average": { "type": "number", "minimum": 0 }
      }
    },
    "learning_impact": {
      "type": "object",
      "properties": {
        "corrections_auto_applied": { "type": "integer", "minimum": 0 },
        "time_saved_by_corrections_minutes": { "type": "integer", "minimum": 0 },
        "patterns_learned": { "type": "integer", "minimum": 0 },
        "suggestions_accepted_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
